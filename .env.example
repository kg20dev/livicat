# Aptabase Analytics App Key
# Get your key from https://us.aptabase.com
# Copy this file to .env and fill in your key
APTABASE_APP_KEY=

# Sentry Error Reporting Configuration
# Get your DSN from your Sentry project settings
# SENTRY_DSN: Data Source Name for Sentry (required for error reporting)
# SENTRY_ENVIRONMENT: Environment name (development/production) - auto-detected from build
# SENTRY_RELEASE: Release version (auto-synced with package.json and Cargo.toml)
SENTRY_DSN=https://your-dsn@sentry.io/12345
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=livicat@0.7.6
